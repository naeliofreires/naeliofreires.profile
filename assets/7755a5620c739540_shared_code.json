-300 top-[2px] left-[2px] z-10\"\n                />\n                <label\n                  for=\"toggle\"\n                  class=\"toggle-label block overflow-hidden h-6 rounded-full bg-white/10 cursor-pointer border border-white/5\"\n                ></label>\n              </div>\n            </div>\n            <div>\n              <div class=\"text-sm font-medium text-white tracking-tight mt-4\">\n                Dark Mode\n              </div>\n              <div class=\"text-[10px] text-white/40 mt-1\">System Default</div>\n            </div>\n          </div>\n\n          <!-- Skill Stack / Visual -->\n          <div\n            class=\"ios-glass rounded-[32px] col-span-2 row-span-1 p-6 flex items-center justify-between relative overflow-hidden group\"\n          >\n            <div class=\"relative z-10\">\n              <h4 class=\"text-white font-medium text-lg tracking-tight\">\n                Experience\n              </h4>\n              <div class=\"flex gap-3 mt-3\">\n                <i\n                  data-lucide=\"figma\"\n                  class=\"w-5 h-5 text-white/60 hover:text-[#81D8D0] transition-colors\"\n                ></i>\n                <i\n                  data-lucide=\"framer\"\n                  class=\"w-5 h-5 text-white/60 hover:text-[#81D8D0] transition-colors\"\n                ></i>\n                <i\n                  data-lucide=\"code-2\"\n                  class=\"w-5 h-5 text-white/60 hover:text-[#81D8D0] transition-colors\"\n                ></i>\n              </div>\n            </div>\n\n            <!-- Abstract Shape -->\n            <div\n              class=\"absolute right-[-20px] bottom-[-40px] w-32 h-32 bg-gradient-to-br from-[#81D8D0] to-transparent rounded-full opacity-20 blur-2xl group-hover:opacity-30 transition-opacity duration-500\"\n            ></div>\n          </div>\n        </div>\n      </div>\n    </main>\n\n    <!-- Selected Work Section -->\n    <section\n      id=\"services\"\n    